{
  "name": "secure-storage-ts",
  "version": "1.0.6",
  "description": "A framework-agnostic secure storage utility for encrypting, securely storing and retrieving app browser storage",
  "author": "MadeByRaymond (Daniel Obiekwe)",
  "keywords": [
    "typescript",
    "javascript",
    "local",
    "session",
    "storage",
    "secure",
    "encrypted",
    "localstorage",
    "sessionstorage",
    "security",
    "encryption",
    "crypto",
    "vanilla-js"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "prepare": "npm run build",
    "test": "vitest run",
    "test-locally": "npm run build && npm link"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "crypto-es": "3.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
